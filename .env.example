# Copy to .env and fill in. docker-compose reads this automatically.

# Trilium ETAPI token. Create one in Trilium: Options -> ETAPI -> "Create new ETAPI token".
TRILIUM_ETAPI_TOKEN=

# Optional: bearer token that MCP clients must present to reach the MCP endpoint.
# Leave empty to expose the endpoint without authentication (only safe when it is
# not reachable beyond localhost / a trusted network).
MCP_AUTH_TOKEN=
