@startuml architecture
!include theme.iuml
title Trilium ETAPI MCP — deployment

left to right direction
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 130
skinparam defaultTextAlignment center

together {
    actor "MCP client\n(via reverse proxy)" as C1
    actor "MCP client\n(direct, trusted LAN)" as C2
}

rectangle "reverse proxy\n(optional — TLS)" as Proxy #line:94A3B8;back:F8FAFC;text:64748B

rectangle "Docker host / compose network" as Host #F8FAFC {
    rectangle "trilium-mcp\n(this repo)\n:8081 /mcp" as MCP #line:4CA53E;back:98D486
    rectangle "trilium\n:8080 /etapi" as Trilium
    database "trilium-data\n(volume)" as Data
}

C1 --> Proxy : HTTPS
C2 --> MCP : HTTP (LAN)
Proxy --> MCP : /mcp
MCP --> Trilium : ETAPI
Trilium --> Data : notes

@enduml
