' Shared theme for the trilium-mcp diagrams.
' Palette taken from the Trilium flower logo:
'   green  #4CA53E  (primary accent)   fill #98D486
'   orange #E6832E                     fill #F4C48D
'   red    #DA3B33                     fill #F2A7A1
' Neutrals: slate greys. No shadows, rounded corners.
' Included by the .puml files via `!include theme.iuml`.

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam defaultFontColor #1E293B
skinparam shadowing false
skinparam roundCorner 12

skinparam titleFontColor #0F172A
skinparam titleFontSize 16

skinparam ArrowColor #4CA53E
skinparam ArrowFontColor #475569

' --- component / deployment ---
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #CBD5E1
    FontColor #1E293B
}
skinparam database {
    BackgroundColor #FFFFFF
    BorderColor #CBD5E1
    FontColor #1E293B
}
skinparam actor {
    BackgroundColor #F1F5F9
    BorderColor #64748B
    FontColor #1E293B
}

' --- sequence ---
skinparam sequence {
    ArrowThickness 1
    LifeLineBorderColor #CBD5E1
    LifeLineBackgroundColor #F8FAFC
    ParticipantBorderColor #CBD5E1
    ParticipantBackgroundColor #FFFFFF
    ParticipantFontColor #1E293B
    ActorBorderColor #64748B
    ActorBackgroundColor #F1F5F9
    BoxBorderColor #CBD5E1
    BoxBackgroundColor #F8FAFC
    GroupBorderColor #CBD5E1
    GroupBackgroundColor #F1F5F9
    GroupHeaderFontColor #0F172A
    DividerBackgroundColor #D7EFCC
    DividerBorderColor #CBD5E1
    DividerFontColor #0F172A
}
skinparam note {
    BackgroundColor #F8FAFC
    BorderColor #CBD5E1
    FontColor #475569
}
